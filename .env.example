DOCKERHUB_USER=
DOCKERHUB_TOKEN=dckr_pat_.....GWw
# Gotify Trigger - WUD_TRIGGER_GOTIFY_LOCAL_TOKEN
GOTIFY_URL=
GOTIFY_TOKEN=AEEW......
# Basic Auth
WUD_SFUSER=
WUD_SFHASH=

